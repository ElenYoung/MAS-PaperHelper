# ============================
# MAS-PaperHelper .env Example
# Only sensitive LLM-related configurations need to be set here.
# All other settings can be edited directly in config/config.yaml
# ============================

# LLM Provider Configuration (Required)
MAS_LLM_PROVIDER=openai
MAS_BASE_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct
MAS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
MAS_BASE_MODEL_API_BASE=http://127.0.0.1:8000/v1
MAS_EMBEDDING_API_BASE=http://127.0.0.1:8001/v1

# API Key Configuration (Required)
MAS_LLM_API_KEY_ENV=OPENAI_API_KEY
OPENAI_API_KEY=

# Optional: Unified API base fallback
MAS_LLM_API_BASE=

# Optional: ClickHouse DSN (contains password)
MAS_CLICKHOUSE_DSN=
