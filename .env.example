# ============================
# MAS-PaperHelper .env Example
# ============================

# --- Required in most deployments ---
MAS_LLM_PROVIDER=openai
MAS_BASE_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct
MAS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
MAS_BASE_MODEL_API_BASE=http://127.0.0.1:8000/v1
MAS_EMBEDDING_API_BASE=http://127.0.0.1:8001/v1

# Bind which env var the app should read as API key
MAS_LLM_API_KEY_ENV=OPENAI_API_KEY
OPENAI_API_KEY=

# --- Optional summary controls ---
MAS_USE_LLM_SUMMARY=false
MAS_SUMMARY_LANGUAGE=zh
MAS_SUMMARY_MAX_CHARS=1000
MAS_SUMMARY_LIMIT=8

# --- Optional retrieval controls ---
MAS_RANKING_THRESHOLD=4.0
MAS_MIN_RELEVANCE_RATIO=0.2
MAS_RECENCY_WINDOW_DAYS=60
MAS_DISCOVERY_LIMIT_PER_SOURCE=10

# --- Optional parser controls ---
MAS_PARSER_BACKEND=pypdf
MAS_PARSER_MAX_PAGES=20

# --- Optional query controls ---
MAS_AUTO_QUERY_FROM_INTERESTS=true
MAS_AUTO_QUERY_MODE=interests

# --- Optional keyword KB controls ---
MAS_KEYWORD_KB_ENABLED=true
MAS_KEYWORD_KB_PATH=data/keyword_kb.json
MAS_KEYWORD_EXPAND_LIMIT=5
MAS_KEYWORD_MAX_NEW_TERMS_PER_RUN=10

# --- Optional source toggles ---
MAS_ARXIV_ENABLED=true
MAS_SEMANTIC_SCHOLAR_ENABLED=true
MAS_BIORXIV_MEDRXIV_RSS_ENABLED=false
MAS_GOOGLE_SCHOLAR_ENABLED=true

# --- Optional database/vector controls ---
MAS_DB_BACKEND=sqlite
MAS_SQLITE_PATH=data/app.db
MAS_CLICKHOUSE_DSN=
MAS_VECTOR_BACKEND=none
MAS_CHROMA_PATH=data/vector_db

# --- Optional user profile override ---
MAS_USER_ID=quant
